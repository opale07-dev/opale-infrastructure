# Variables runtime du backend Vault — le fichier réel app.env est écrit par
# vault-app-deploy.yml depuis les secrets GitHub d'opale-infrastructure.
# Ce template documente exactement ce qui est écrit (rien d'autre).

# Unseal par TPM (obligatoire en prod ; jamais de VAULT_MASTER_PASSPHRASE ici)
VAULT_UNSEAL_MODE=tpm
VAULT_TPM_NV_INDEX=0x1500016

# Allow-list CSV des wallets admin (secret VAULT_ADMIN_PUBKEYS).
# ⚠️ CSV entre guillemets sinon docker compose tronque au premier élément.
VAULT_ADMIN_PUBKEYS="<pubkey1>,<pubkey2>"
